{
  "name": "headunit",
  "version": "0.1.0",
  "description": "Headless Content Management System powered by AppWrite",
  "author": "Aris Ripandi",
  "homepage": "https://github.com/riipandi/headunit",
  "keywords": [
    "cms",
    "headless",
    "content",
    "appwrite",
    "content",
    "markdown"
  ],
  "repository": {
    "type": "git",
    "url": "git://github.com/riipandi/headunit.git"
  },
  "bugs": "https://github.com/riipandi/headunit/issues",
  "contributors": [
    "https://github.com/riipandi/headunit/graphs/contributors"
  ],
  "license": "MIT",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "eslint src --fix && yarn format",
    "format": "prettier --write src"
  },
  "dependencies": {
    "@emotion/is-prop-valid": "^1.1.0",
    "@headlessui/react": "^1.4.1",
    "@heroicons/react": "^1.0.4",
    "@tailwindcss/aspect-ratio": "^0.2.2",
    "@tailwindcss/forms": "^0.3.4",
    "@tailwindcss/line-clamp": "^0.2.2",
    "@tailwindcss/typography": "^0.4.1",
    "framer-motion": "^4.1.17",
    "next": "^11.1.2",
    "next-themes": "^0.0.15",
    "node-appwrite": "^2.5.0",
    "phosphor-react": "^1.3.1",
    "react": "17.0.2",
    "react-dom": "17.0.2"
  },
  "devDependencies": {
    "@types/node": "^16.10.2",
    "@types/react": "^17.0.27",
    "@types/tailwindcss": "^2.2.1",
    "@typescript-eslint/eslint-plugin": "^4.32.0",
    "@typescript-eslint/parser": "^4.32.0",
    "autoprefixer": "^10.3.6",
    "clsx": "^1.1.1",
    "eslint": "7.32.0",
    "eslint-config-next": "11.1.2",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-simple-import-sort": "^7.0.0",
    "lint-staged": "^11.1.2",
    "postcss": "^8.3.6",
    "prettier": "^2.4.1",
    "sharp": "^0.29.1",
    "tailwindcss": "^2.2.16",
    "typescript": "^4.4.3"
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx,}": [
      "eslint --max-warnings=0",
      "prettier -w"
    ],
    "src/**/*.{json,css,scss,md}": [
      "prettier -w"
    ]
  },
  "browserslist": [
    ">0.2%",
    "not dead",
    "not ie <= 11",
    "not op_mini all"
  ]
}
